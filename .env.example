# Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Redis
REDIS_URL=redis://redis:6379

# Admin Setup
ADMIN_SETUP_KEY=your_admin_setup_key_here

# Encryption Keys
PAYLOAD_ENCRYPTION_KEY=RGlwbG9tYVZlcmlmeUFFUzI1NlNlY3JldEtleTB4T0s=
ENCRYPTION_KEY=your_encryption_key_here
SECRET_SALT=your_secret_salt_here

# Service URLs (for internal communication)
NOTIFICATION_SERVICE_URL=http://notification-service:8008
AUTH_SERVICE_URL=http://auth-service:8001
FILE_SERVICE_URL=http://file-service:8005
UNIVERSITY_SERVICE_URL=http://university-service:8002
CERTIFICATE_SERVICE_URL=http://certificate-service:8006
AI_SERVICE_URL=http://ai-integration-service:8007
BLOCKCHAIN_SERVICE_URL=http://blockchain-service:8009
HTTP_CLIENT_TIMEOUT=10
UPLOAD_HTTP_TIMEOUT=120
DOCS_AGGREGATOR_CACHE_TTL=30

# Demo Mode
DEMO_MODE=true

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true
DEFAULT_SENDER=noreply@yourdomain.com
