# Swagger OpenAPI: после docker compose up — http://127.0.0.1:18001/docs … 18008/docs
# (порты заданы в docker-compose.yml; снаружи Caddy только :80)

# Обязательные секреты (без дефолтов в коде для JWT/SECRET_SALT)
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_ALGORITHM=HS256
SECRET_SALT=change_me_secret_salt_min_32_chars

REDIS_URL=redis://redis:6379
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Отдельная БД на сервис (создаются скриптом infra/postgres-init при первом старте тома)
DATABASE_URL_AUTH=postgresql://hack:hack@postgres:5432/authdb
DATABASE_URL_UNIVERSITY=postgresql://hack:hack@postgres:5432/universitydb
DATABASE_URL_VERIFY=postgresql://hack:hack@postgres:5432/verifydb
DATABASE_URL_FILE=postgresql://hack:hack@postgres:5432/filedb
DATABASE_URL_CERT=postgresql://hack:hack@postgres:5432/certdb
DATABASE_URL_NOTIFICATION=postgresql://hack:hack@postgres:5432/notificationdb

AUTH_SERVICE_URL=http://auth-service:8001
UNIVERSITY_SERVICE_URL=http://university-service:8002
DIPLOMA_SERVICE_URL=http://diploma-service:8003
VERIFY_SERVICE_URL=http://verify-service:8004
FILE_SERVICE_URL=http://file-service:8005
CERTIFICATE_SERVICE_URL=http://certificate-service:8006
AI_SERVICE_URL=http://ai-integration-service:8007
NOTIFICATION_SERVICE_URL=http://notification-service:8008

HTTP_CLIENT_TIMEOUT=10
UPLOAD_HTTP_TIMEOUT=120
AI_FILE_FETCH_TIMEOUT=120

VERIFY_PUBLIC_BASE_URL=http://localhost

# Опционально: DELETE /files/{id} (заголовок X-Internal-Token)
# FILE_INTERNAL_DELETE_TOKEN=

# Локальная разработка Postgres (в compose задаётся в docker-compose.yml)
# POSTGRES_USER=hack
# POSTGRES_PASSWORD=hack
# POSTGRES_DB=diplomadb
