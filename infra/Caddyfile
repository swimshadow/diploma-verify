:80 {
  @docs path /docs /docs/*
  handle @docs {
    uri strip_prefix /docs
    reverse_proxy docs_service:8000
  }

  @api path /api/*
  reverse_proxy @api api:8000

  route /auth/* {
    uri strip_prefix /auth
    reverse_proxy auth_service:8002
  }

  route /users/* {
    uri strip_prefix /users
    reverse_proxy user_service:8001
  }

  route /products/* {
    uri strip_prefix /products
    reverse_proxy products_service:8080
  }

  route /orders/* {
    uri strip_prefix /orders
    reverse_proxy orders_service:3000
  }

  route /notifications/* {
    uri strip_prefix /notifications
    reverse_proxy notifications_service:8003
  }

  route /reviews/* {
    uri strip_prefix /reviews
    reverse_proxy reviews_service:8004
  }

  route /categories/* {
    uri strip_prefix /categories
    reverse_proxy categories_service:3001
  }

  route /tags/* {
    uri strip_prefix /tags
    reverse_proxy tags_service:3002
  }

  route /inventory/* {
    uri strip_prefix /inventory
    reverse_proxy inventory_service:8085
  }

  route /shipping/* {
    uri strip_prefix /shipping
    reverse_proxy shipping_service:5000
  }

  route /payments/* {
    uri strip_prefix /payments
    reverse_proxy payments_service:8086
  }

  route /comments/* {
    uri strip_prefix /comments
    reverse_proxy comments_service:3003
  }

  route /coupons/* {
    uri strip_prefix /coupons
    reverse_proxy coupons_service:8087
  }

  route /analytics/* {
    uri strip_prefix /analytics
    reverse_proxy analytics_service:8088
  }

  @health path_regexp ^/health/?$
  reverse_proxy @health api:8000

  root * /var/www/html
  file_server {
    index index.html
  }
}

