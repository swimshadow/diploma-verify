# Скопируйте в .env и подставьте секреты.

JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_ALGORITHM=HS256
SECRET_SALT=change_me_secret_salt_min_32_chars

# Ключ Fernet (44 символа base64). Генерация:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

DEMO_MODE=true
ADMIN_SETUP_KEY=change_me_admin_setup_secret

REDIS_URL=redis://redis:6379
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

VERIFY_PUBLIC_BASE_URL=http://localhost:8000

DATABASE_URL=postgresql://hack:hack@postgres:5432/diplomadb

HTTP_CLIENT_TIMEOUT=10
UPLOAD_HTTP_TIMEOUT=120
AI_FILE_FETCH_TIMEOUT=120
