:80 {
	header {
		Access-Control-Allow-Origin *
		Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
		Access-Control-Allow-Headers "Authorization, Content-Type, Accept, X-Encrypted"
		Access-Control-Expose-Headers "X-Encrypted"
		Access-Control-Max-Age 3600
	}

	@options method OPTIONS
	handle @options {
		respond 204
	}

	@docs path /docs /docs/*
	handle @docs {
		uri strip_prefix /docs
		reverse_proxy docs_service:8000
	}

	handle /api/auth/* {
		uri strip_prefix /api
		reverse_proxy auth-service:8001
	}

	handle /api/university/* {
		uri strip_prefix /api
		reverse_proxy university-service:8002
	}

	handle /api/student/* {
		uri strip_prefix /api
		reverse_proxy diploma-service:8003
	}

	handle /api/employer/* {
		uri strip_prefix /api
		reverse_proxy diploma-service:8003
	}

	handle /api/verify/* {
		uri strip_prefix /api
		reverse_proxy verify-service:8004
	}

	handle /api/files/* {
		uri strip_prefix /api
		reverse_proxy file-service:8005
	}

	handle /api/certificates/* {
		uri strip_prefix /api
		reverse_proxy certificate-service:8006
	}

	handle /api/ai/* {
		uri strip_prefix /api
		reverse_proxy ai-integration-service:8007
	}

	handle /api/blockchain/* {
		uri replace /api/blockchain /blockchain
		reverse_proxy blockchain-service:8009
	}

	handle /api/admin/* {
		uri replace /api/admin /admin
		reverse_proxy admin-service:8010
	}

	handle /api/mail/* {
		uri strip_prefix /api/mail
		reverse_proxy mail-service:8000
	}

	handle /api/internal/* {
		uri strip_prefix /api
		reverse_proxy notification-service:8008
	}

	@notifications path /api/notifications /api/notifications/*
	handle @notifications {
		uri strip_prefix /api
		reverse_proxy notification-service:8008
	}

	handle /verify/* {
		reverse_proxy verify-service:8004
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
