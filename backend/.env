# Обязательные секреты
JWT_SECRET=change_me_jwt_secret_at_least_32_chars_long
SECRET_SALT=change_me_secret_salt_32_chars_min

# Опциональные (есть дефолты в docker-compose.yml)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
REDIS_URL=redis://redis:6379
HTTP_CLIENT_TIMEOUT=10
UPLOAD_HTTP_TIMEOUT=120
AI_FILE_FETCH_TIMEOUT=120
VERIFY_PUBLIC_BASE_URL=http://localhost:8000
FILE_INTERNAL_DELETE_TOKEN=
DOCS_AGGREGATOR_CACHE_TTL=30
